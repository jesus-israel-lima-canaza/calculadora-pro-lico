rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole(userId) {
      return get(/databases/$(database)/documents/roles/$(userId)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/roles/$(request.auth.uid)) && get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'admin') ||
        request.auth.token.email.lower() == 'jesus.israel.lima.canaza@gmail.com'
      );
    }

    function isStaff() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/roles/$(request.auth.uid)) && (get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role in ['admin', 'staff'])) ||
        request.auth.token.email.lower() == 'jesus.israel.lima.canaza@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.totalCost is number && data.totalCost >= 0;
    }

    function isValidSettings(data) {
      return data.commissions is map &&
             data.commissions.debit is number && data.commissions.debit >= 0 && data.commissions.debit <= 100 &&
             data.commissions.credit is number && data.commissions.credit >= 0 && data.commissions.credit <= 100 &&
             data.commissions.delivery is number && data.commissions.delivery >= 0 && data.commissions.delivery <= 100;
    }

    // Role Assignments
    match /roles/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isAdmin();
      allow delete: if isAdmin(); 
    }

    // Collection Rules
    match /users/{userId} {
      match /products/{productId} {
        allow get, list: if isOwner(userId) || isStaff();
        allow create, update, delete: if (isOwner(userId) || isStaff()) && isValidId(productId) && (request.method != 'delete' ? isValidProduct(incoming()) : true);
      }

      match /settings/config {
        allow get: if isOwner(userId) || isStaff();
        allow write: if (isOwner(userId) || isAdmin()) && isValidSettings(incoming());
      }
    }
  }
}
